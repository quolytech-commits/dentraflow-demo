# ============================================================
# DentraFlow — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.

# ------------------------------------------------------------
# DATABASE (Neon PostgreSQL)
# ------------------------------------------------------------
# Get these from console.neon.tech → your project → Connection Details
# Use the "Pooled connection" string for DATABASE_URL
# Use the "Direct connection" string for DIRECT_URL

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require"

# ------------------------------------------------------------
# JWT SECRET
# ------------------------------------------------------------
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-this-with-a-64-char-random-hex-secret"

# ------------------------------------------------------------
# APP URL (for production, set to your Vercel domain)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
